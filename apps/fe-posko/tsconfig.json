{
	"compilerOptions": {
		"esModuleInterop": true,
		"target": "ES2020",
		"lib": ["DOM", "ES2020"],
		"module": "ESNext",
		"jsx": "react-jsx",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"useDefineForClassFields": true,
		"allowImportingTsExtensions": true,
		"allowJs": true,
		"baseUrl": "./src",
		"paths": {
			"@common/*": ["common/*"],
			"@component/*": ["components/*"],
			"@constants/*": ["constants/*"],
			"@store/*": ["store/*"],
			"@hooks/*": ["hooks/*"],
			"@types/*": ["types/*"],
			"@utils/*": ["utils/*"],
			"@streams/*": ["streams/*"]
		}
	},
	"include": ["src", "jest.config.ts", "jest.setup.ts", "__mocks__"],
	"ts-node": {
		"compilerOptions": {
			"module": "CommonJS",
			"types": ["jest", "jest-extended"]
		}
	}
}
